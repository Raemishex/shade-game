{
  "name": "shade",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "check-ip": "node scripts/get-ip.js",
    "start": "next start",
    "lint": "next lint",
    "server": "node server/index.js",
    "dev:all": "node scripts/start-network.js",
    "start:prod": "concurrently -n socket,next -c blue,green \"node server/index.js\" \"next start --hostname 0.0.0.0 -p 3000\"",
    "seed": "npx ts-node scripts/seed-words.ts",
    "seed:force": "npx ts-node scripts/seed-words.ts --force",
    "test": "jest --verbose 2>&1 | grep -v 'Force exiting Jest'",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "framer-motion": "^12.38.0",
    "howler": "^2.2.4",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.1",
    "next": "14.2.35",
    "next-pwa": "^5.6.0",
    "react": "^18",
    "react-dom": "^18",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/howler": "^2.2.12",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "concurrently": "^9.0.0",
    "dotenv": "^17.3.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "jest": "^30.3.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
